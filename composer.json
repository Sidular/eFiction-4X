{
    "name": "efiction/efiction-modern",
    "description": "Modernized eFiction fanfiction archive (PHP 8.x compatible)",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-session": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "scripts": {
        "lint": "find . -name '*.php' -not -path './vendor/*' -not -path './install/*' -print0 | xargs -0 -n1 php -l",
        "analyze": "phpstan analyse includes header.php index.php --level=0 || true"
    }
}
