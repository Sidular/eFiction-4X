{
    "name": "efiction/efiction",
    "description": "eFiction 4.0.0 - A modern PHP 8.3 fanfiction archive.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-session": "*",
        "ext-json": "*",
        "ext-fileinfo": "*",
        "ext-openssl": "*"
    },
    "suggest": {
        "phpmailer/phpmailer": "^6.9 (only needed if you prefer PHPMailer over the built-in mail/SMTP implementation)"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "eFiction\\": "src/"
        }
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "lint": "find . -name '*.php' -not -path './vendor/*' -not -path './storage/*' -print0 | xargs -0 -n1 php -l",
        "analyze": "phpstan analyse src --level=5 || true"
    }
}
