/public/uploads/

# IDE and editor files
/.idea/
/.vscode/
*.swp
*.swo
*~
.DS_Store

# OS files
Thumbs.db
desktop.ini

# Backup and archive files
*.backup
*.bak
*.tar.gz
*.zip

# PHP error logs
*.log

# Install lock file
/install/install.lock
