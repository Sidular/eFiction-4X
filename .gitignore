# Composer dependencies
/vendor/
composer.lock

# Configuration files (local only)
/config.php

# Environment files
.env
.env.local

# Storage and runtime data
/storage/cache/*
/storage/logs/*
/storage/stories/*
/storage/images/*
!/storage/cache/.gitkeep
!/storage/logs/.gitkeep
!/storage/stories/.gitkeep
!/storage/images/.gitkeep

